# Maintainer: Mainstream <https://github.com/gregorytrentmartinjr/archiso>
# Based on the AUR calamares package.
#
# Differences from upstream:
#   - pkgname is calamares-mainstream (provides/conflicts calamares)
#   - data/images/state-ok.svg    replaced with green-password-met.svg
#   - data/images/state-error.svg replaced with red-password-not-met.svg
#     Those two files are the password-met / password-not-met indicator icons
#     shown on the Users page.  They are compiled into libcalamaresui as Qt
#     resources and must be patched before cmake runs.
#   - mainstream-font.patch
#     Sets the application font to the dotfiles font stack (Google Sans Flex
#     → Noto Sans → DejaVu Sans) early in main() so every widget inherits it.
#   - mainstream-window.patch
#     Makes the window frameless (Qt::FramelessWindowHint) so Hyprland draws
#     its compositor-level rounding and shadows.  Adds mousePressEvent with
#     startSystemMove() so the window can still be dragged by clicking the
#     top navigation-bar strip.
#   - mainstream-partition.patch
#     Fixes partition-label text colours: replaces the hardcoded Qt::black /
#     Qt::gray QPainter pens with palette().color(Text/PlaceholderText) so
#     the labels are visible on the dark theme.  Also increases CORNER_RADIUS
#     from 2 → 6 (M3-style rounded partition colour squares) and removes the
#     hardcoded border pen on those squares.
#   - sed in prepare(): strips keyboard-shortcut & ampersands from every
#     navigation button label (Back, Next, Cancel, Done, Install, Set Up).

pkgname=calamares-mainstream
pkgver=3.3.14
pkgrel=2
pkgdesc='Distribution-independent installer framework (Mainstream edition)'
arch=('x86_64')
url='https://calamares.io'
license=('GPL-3.0-only' 'LGPL-2.1-or-later')

depends=(
    # KDE Frameworks 6 — Arch packages use bare names (no kf6- prefix)
    'kconfig'
    'kcoreaddons'
    'kiconthemes'
    'ki18n'
    'kio'
    'solid'
    'kpackage'
    # Qt 6
    'qt6-base'
    'qt6-svg'
    'qt6-declarative'
    'qt6-5compat'
    # Disk / partition tools
    'kpmcore'
    'parted'
    'udisks2'
    'polkit-qt6'
    # Misc runtime
    'boost-libs'
    'yaml-cpp'
    'hwinfo'
    'libpwquality'
    'squashfs-tools'
    'efibootmgr'
    'gtk-update-icon-cache'
    'icu'
    'python'
    # Note: ckbcomp (keyboard layout tool) is AUR-only on Arch.
    # It is listed in packages.x86_64 and built via AUR_DEPS in
    # build-packages.sh rather than declared here to avoid dep-resolution
    # failures during makepkg -s.
)

makedepends=(
    'extra-cmake-modules'
    'qt6-tools'
    'boost'
    'cmake'
    'ninja'
    'git'
)

provides=('calamares')
conflicts=('calamares')

source=(
    # Official upstream release tarball
    "https://github.com/calamares/calamares/releases/download/v${pkgver}/calamares-${pkgver}.tar.gz"
    # Mainstream custom password indicator icons.
    # These replace data/images/state-ok.svg and data/images/state-error.svg
    # inside the source tree before compilation so they are compiled into
    # libcalamaresui as Qt resources.
    "green-password-met.svg"
    "red-password-not-met.svg"
    # Mainstream source patches
    "mainstream-font.patch"
    "mainstream-window.patch"
    "mainstream-partition.patch"
)

# sha256sums[0] can be updated with: sha256sum calamares-${pkgver}.tar.gz
# Local sources (SVGs and patches) are verified by git history.
sha256sums=(
    'SKIP'
    'SKIP'
    'SKIP'
    'SKIP'
    'SKIP'
    'SKIP'
)

prepare() {
    cd "calamares-${pkgver}"

    # ── Icon substitution ──────────────────────────────────────────────────
    # Replace the built-in status icons with Mainstream branding icons.
    cp "${srcdir}/green-password-met.svg"   data/images/state-ok.svg
    cp "${srcdir}/red-password-not-met.svg" data/images/state-error.svg

    # ── Source patches ─────────────────────────────────────────────────────
    patch -p1 < "${srcdir}/mainstream-font.patch"
    patch -p1 < "${srcdir}/mainstream-window.patch"
    patch -p1 < "${srcdir}/mainstream-partition.patch"

    # ── Navigation button labels: strip keyboard-shortcut ampersands ───────
    # CalamaresWindow.cpp — initial button text at widget creation
    sed -i 's/"&Back"/"Back"/g'     src/calamares/CalamaresWindow.cpp
    sed -i 's/"&Next"/"Next"/g'     src/calamares/CalamaresWindow.cpp
    sed -i 's/"&Cancel"/"Cancel"/g' src/calamares/CalamaresWindow.cpp

    # ViewManager.cpp — dynamic labels set/updated at runtime
    sed -i \
        -e 's/tr( "&Next",     "@button" )/tr( "Next",     "@button" )/g' \
        -e 's/tr( "&Back",     "@button" )/tr( "Back",     "@button" )/g' \
        -e 's/tr( "&Cancel",   "@button" )/tr( "Cancel",   "@button" )/g' \
        -e 's/tr( "&Done",     "@button" )/tr( "Done",     "@button" )/g' \
        -e 's/tr( "&Install",  "@button" )/tr( "Install",  "@button" )/g' \
        -e 's/tr( "&Set Up",   "@button" )/tr( "Set Up",   "@button" )/g' \
        src/libcalamaresui/ViewManager.cpp
    # Multi-word labels with spaces that vary by mode
    sed -i \
        -e 's/tr( "&Install Now", "@button" )/tr( "Install Now", "@button" )/g' \
        -e 's/tr( "&Set Up Now",  "@button" )/tr( "Set Up Now",  "@button" )/g' \
        -e 's/tr( "Go &Back",     "@button" )/tr( "Go Back",     "@button" )/g' \
        src/libcalamaresui/ViewManager.cpp
}

build() {
    cd "calamares-${pkgver}"

    cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_INSTALL_LIBDIR=lib \
        -DWITH_QT6=ON \
        -DWITH_PYTHONQT=OFF \
        -DBoost_NO_BOOST_CMAKE=ON \
        -DSKIP_MODULES="tracking webview interactiveterminal \
                        dracut dracutlukscfg \
                        dummyprocess dummypython dummycpp dummypythonqt \
                        services-openrc"

    cmake --build build
}

package() {
    cd "calamares-${pkgver}"
    DESTDIR="${pkgdir}" cmake --install build
}

#!/usr/bin/env bash
# =============================================================================
# dotfiles-first-login
# Installed as /etc/profile.d/dotfiles-first-login.sh
# Runs once on first interactive login after installation.
# =============================================================================
MARKER="$HOME/.dotfiles-pending-user-setup"
[[ -f "$MARKER" ]] || return 0
[[ -n "$WAYLAND_DISPLAY" || -n "$DISPLAY" ]] || return 0

# Only run once
rm -f "$MARKER"

DOTFILES_DIR="$HOME/dots-hyprland"
[[ -d "$DOTFILES_DIR" ]] || DOTFILES_DIR="/opt/dots-hyprland"

VENV_PATH="$HOME/.local/state/quickshell/.venv"
DEFAULT_WALL="$HOME/.config/quickshell/ii/assets/images/default_wallpaper.png"
SWITCHWALL="$HOME/.config/quickshell/ii/scripts/colors/switchwall.sh"

# ---------------------------------------------------------------------------
# PHASE 1: Immediate — runs fast, no venv needed
# Fix dark mode and initial colors RIGHT NOW before anything else
# ---------------------------------------------------------------------------
(
    sleep 3

    # Fix dark mode immediately
    if command -v gsettings &>/dev/null; then
        gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
        gsettings set org.gnome.desktop.interface gtk-theme 'adw-gtk3-dark' 2>/dev/null || true
        gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark' 2>/dev/null || true
        gsettings set org.gnome.desktop.interface font-name 'Google Sans Flex Medium 11 @opsz=11,wght=500' 2>/dev/null || true
        gsettings set org.gnome.desktop.wm.preferences button-layout ":" 2>/dev/null || true
        echo "[first-login] Dark mode set."
    fi

    # Run matugen immediately for basic color templates (hyprland colors, fuzzel, gtk)
    # This doesn't need the venv — just matugen itself
    if [[ -f "$DEFAULT_WALL" ]] && command -v matugen &>/dev/null; then
        mkdir -p "$HOME/.local/state/quickshell/user/generated/wallpaper"
        matugen image "$DEFAULT_WALL" --mode dark 2>/dev/null || true
        echo "[first-login] Basic colors generated via matugen."
    fi

    # Reload Hyprland config to pick up new colors
    sleep 1
    hyprctl reload 2>/dev/null || true

) &>/tmp/dotfiles-first-login-phase1.log &
disown

# ---------------------------------------------------------------------------
# PHASE 2: Slow — venv setup + full color pipeline
# Runs in background, takes 2-3 minutes
# ---------------------------------------------------------------------------
(
    sleep 5

    # ydotool user service
    if systemctl --user list-unit-files ydotool.service &>/dev/null 2>&1; then
        systemctl --user enable ydotool --now 2>/dev/null || true
    fi

    # Create venv if it doesn't exist yet
    if [[ ! -f "$VENV_PATH/bin/python" ]]; then
        echo "[first-login] Creating Python venv at $VENV_PATH..."
        mkdir -p "$(dirname "$VENV_PATH")"
        REQUIREMENTS="$DOTFILES_DIR/sdata/uv/requirements.txt"

        if command -v uv &>/dev/null && [[ -f "$REQUIREMENTS" ]]; then
            uv venv "$VENV_PATH"
            uv pip install --python "$VENV_PATH/bin/python" -r "$REQUIREMENTS"
            echo "[first-login] Venv created."
        else
            echo "[first-login] WARNING: uv or requirements.txt not found"
        fi
    else
        echo "[first-login] Venv already exists at $VENV_PATH"
    fi

    # Write env var to shell configs
    FISH_ENV_DIR="$HOME/.config/fish/conf.d"
    mkdir -p "$FISH_ENV_DIR"
    echo "set -gx ILLOGICAL_IMPULSE_VIRTUAL_ENV '$VENV_PATH'" \
        > "$FISH_ENV_DIR/illogical-impulse-venv.fish"
    grep -q "ILLOGICAL_IMPULSE_VIRTUAL_ENV" "$HOME/.bashrc" 2>/dev/null || \
        echo "export ILLOGICAL_IMPULSE_VIRTUAL_ENV='$VENV_PATH'" >> "$HOME/.bashrc"

    # Run full switchwall pipeline now that venv exists
    # This generates terminal/kitty-theme.conf and material_colors.scss
    if [[ -f "$VENV_PATH/bin/python" ]] && [[ -f "$SWITCHWALL" ]]; then
        echo "[first-login] Running full color pipeline..."
        export ILLOGICAL_IMPULSE_VIRTUAL_ENV="$VENV_PATH"
        bash "$SWITCHWALL" --image "$DEFAULT_WALL" --mode dark 2>/dev/null || true
        echo "[first-login] Full color pipeline complete."

        # Restart Quickshell to pick up kitty-theme.conf
        pkill qs 2>/dev/null || true
        sleep 2
        qs -c ii &>/dev/null &
        disown
        echo "[first-login] Quickshell restarted with updated colors."
    fi

    # Notify user
    if command -v notify-send &>/dev/null; then
        notify-send "Setup Complete" \
            "Your Hyprland desktop is fully configured!" \
            --icon=system-software-install 2>/dev/null || true
    fi

    echo "[first-login] All done."

) &>/tmp/dotfiles-first-login.log &
disown

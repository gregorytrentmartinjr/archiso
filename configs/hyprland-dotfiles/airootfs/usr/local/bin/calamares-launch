#!/usr/bin/env bash
# Launch Calamares installer (run as liveuser, elevates internally)
if [ "$(id -u)" -eq 0 ]; then
    exec calamares
else
    exec pkexec env \
        DISPLAY="$DISPLAY" \
        WAYLAND_DISPLAY="$WAYLAND_DISPLAY" \
        XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
        QT_QPA_PLATFORM="$QT_QPA_PLATFORM" \
        calamares
fi

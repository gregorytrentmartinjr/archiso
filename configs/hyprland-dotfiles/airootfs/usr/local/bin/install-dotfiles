#!/usr/bin/env bash
# =============================================================================
# install-dotfiles (Fast Pre-Built Package Installation)
# Uses pre-compiled .pkg.tar.zst files baked into the ISO instead of
# building from source — reduces install time from ~15min to under 2min.
# =============================================================================

set -uo pipefail

log()  { echo "[install-dotfiles] $*"; }
info() { log "INFO:  $*"; }
warn() { log "WARN:  $*"; }
die()  { log "FATAL: $*"; exit 1; }

# ---------------------------------------------------------------------------
# 1. ENVIRONMENT PREP
# ---------------------------------------------------------------------------
export TERM=xterm-256color

# Pre-built packages are baked into the ISO at this path
PKG_DIR="/usr/local/share/pkgs"
DOTFILES_REPO="https://github.com/gregorytrentmartinjr/dots-hyprland.git"
DOTFILES_BRANCH="newcustom"

# ---------------------------------------------------------------------------
# 2. IDENTIFY TARGET USER (UID 1000 or 1001)
# ---------------------------------------------------------------------------
EXCLUDE_LIST="liveuser|builduser|nobody|root"
NEW_USER=$(getent passwd | awk -F: '$3 >= 1000 && $3 <= 1001 {print $1}' | grep -vE "($EXCLUDE_LIST)" | head -n 1 || true)
NEW_USER_HOME="/home/$NEW_USER"

if [[ -z "$NEW_USER" ]]; then
    log "ERROR: Could not find user in UID 1000-1001 range. Current passwd entries:"
    getent passwd | awk -F: '$3 >= 1000' | tee /tmp/passwd-debug.txt
    die "Could not identify primary user. Aborting dotfiles install."
fi
info "Target user: $NEW_USER (UID: $(id -u "$NEW_USER"), home: $NEW_USER_HOME)"

# ---------------------------------------------------------------------------
# 3. VERIFY PRE-BUILT PACKAGES EXIST
# ---------------------------------------------------------------------------
if [[ ! -d "$PKG_DIR" ]]; then
    die "Pre-built package directory missing: $PKG_DIR — was build-packages.sh run before building the ISO?"
fi

PKG_COUNT=$(find "$PKG_DIR" -name "*.pkg.tar.zst" 2>/dev/null | wc -l)
if [[ "$PKG_COUNT" -eq 0 ]]; then
    die "No .pkg.tar.zst files found in $PKG_DIR — run build-packages.sh and rebuild the ISO."
fi
info "Found $PKG_COUNT pre-built packages in $PKG_DIR."

# ---------------------------------------------------------------------------
# 4. NETWORK CHECK
# ---------------------------------------------------------------------------
info "Checking network connectivity..."
if ! ping -c1 -W5 github.com &>/dev/null; then
    die "No network connectivity. Cannot clone dotfiles. Aborting."
fi
info "Network OK."

# ---------------------------------------------------------------------------
# 5. ENSURE BUILDUSER EXISTS FOR GIT CLONE
# ---------------------------------------------------------------------------
if ! id "builduser" &>/dev/null; then
    info "Creating builduser for git clone..."
    useradd -m -G wheel builduser
fi

if ! grep -q "builduser" /etc/sudoers /etc/sudoers.d/* 2>/dev/null; then
    info "Adding passwordless sudo for builduser..."
    echo "builduser ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/builduser-install
    chmod 440 /etc/sudoers.d/builduser-install
fi

# ---------------------------------------------------------------------------
# 6. REGISTER LOCAL REPO FOR PRE-BUILT AUR DEPS
# ---------------------------------------------------------------------------
# All AUR runtime dependencies were pre-built by build-packages.sh and are
# available in the local repo at /usr/local/share/pkgs/.  Register it in
# pacman.conf so pacman -U (step 8) can auto-resolve them — no yay needed.
info "Registering local package repo for dependency resolution..."
if [[ -d "$PKG_DIR" ]] && ! grep -q '^\[illogical-impulse\]' /etc/pacman.conf 2>/dev/null; then
    cat >> /etc/pacman.conf << 'LOCALREPO'

[illogical-impulse]
SigLevel = Never
Server = file:///usr/local/share/pkgs
LOCALREPO
    pacman -Sy 2>/dev/null || true
    info "Local repo registered."
else
    info "Local repo already registered or PKG_DIR missing."
fi

# ---------------------------------------------------------------------------
# 7. CLONE DOTFILES FOR ASSET DEPLOYMENT
# ---------------------------------------------------------------------------
USER_DOTFILES="/tmp/dotfiles-setup"
rm -rf "$USER_DOTFILES"
mkdir -p "$USER_DOTFILES"
chown builduser:builduser "$USER_DOTFILES"

info "Cloning dotfiles repository (branch: $DOTFILES_BRANCH)..."
if ! su builduser -c "git clone --depth=1 --recurse-submodules --shallow-submodules --branch '$DOTFILES_BRANCH' '$DOTFILES_REPO' '$USER_DOTFILES'"; then
    die "git clone failed. Check the branch name and repo URL. Aborting."
fi
if [[ -z "$(ls -A "$USER_DOTFILES")" ]]; then
    die "Clone directory is empty after git clone. Aborting."
fi
info "Clone successful."

# ---------------------------------------------------------------------------
# 8. INSTALL PRE-BUILT META-PACKAGES
# ---------------------------------------------------------------------------
METAPKGS=(
    "illogical-impulse-audio"
    "illogical-impulse-backlight"
    "illogical-impulse-basic"
    "illogical-impulse-fonts-themes"
    "illogical-impulse-gnome"
    "illogical-impulse-hyprland"
    "illogical-impulse-kde"
    "illogical-impulse-portal"
    "illogical-impulse-python"
    "illogical-impulse-screencapture"
    "illogical-impulse-toolkit"
    "illogical-impulse-widgets"
    "illogical-impulse-microtex-git"
    "illogical-impulse-quickshell-git"
    "illogical-impulse-extras"
    "illogical-impulse-bibata-modern-classic-bin"
)

SUCCESS_COUNT=0
FAILED_PKGS=()

info "Installing ${#METAPKGS[@]} pre-built meta-packages..."
for pkgname in "${METAPKGS[@]}"; do
    pkgfile=$(find "$PKG_DIR" -name "${pkgname}-*.pkg.tar.zst" | head -1)

    if [[ -z "$pkgfile" ]]; then
        warn "No pre-built package found for $pkgname in $PKG_DIR"
        FAILED_PKGS+=("$pkgname (missing pkg file)")
        continue
    fi

    info "Installing $pkgname from $(basename "$pkgfile")..."
    if pacman -U --noconfirm --needed "$pkgfile" 2>&1; then
        ((SUCCESS_COUNT++)) || true
        info "$pkgname installed successfully."
    else
        warn "Failed to install $pkgname"
        FAILED_PKGS+=("$pkgname")
    fi
done

# ---------------------------------------------------------------------------
# 9. DOTFILES ASSET DEPLOYMENT
# ---------------------------------------------------------------------------
info "Deploying dotfiles to $NEW_USER_HOME..."

DOTS_SOURCE=""
for candidate in \
    "$USER_DOTFILES/dots" \
    "$USER_DOTFILES/.config" \
    "$USER_DOTFILES/home" \
    "$USER_DOTFILES"; do
    if [[ -d "$candidate" ]] && [[ -n "$(ls -A "$candidate")" ]]; then
        if [[ "$candidate" != "$USER_DOTFILES" ]]; then
            DOTS_SOURCE="$candidate"
            break
        fi
    fi
done

if [[ -z "$DOTS_SOURCE" ]]; then
    warn "Could not find a dedicated dots subdirectory — falling back to repo root."
    DOTS_SOURCE="$USER_DOTFILES"
fi

info "Deploying dotfiles from: $DOTS_SOURCE -> $NEW_USER_HOME"
cp -a "$DOTS_SOURCE/." "$NEW_USER_HOME/"
chown -R "$NEW_USER:$NEW_USER" "$NEW_USER_HOME"
info "Dotfiles deployed."

# ---------------------------------------------------------------------------
# 10. OPTIONAL EXTRAS — moved to netinstall.conf
# ---------------------------------------------------------------------------
# Previously, 23 packages (google-chrome, libreoffice, spotify, gimp, etc.)
# were force-installed here via yay, adding 10-30+ minutes to every install.
# They are now user-selectable in the Calamares netinstall step instead.
# See: /etc/calamares/modules/netinstall.conf → "Included Extras" group.
info "Optional extras are now user-selectable in the Calamares package picker."

# ---------------------------------------------------------------------------
# 11. SUMMARY
# ---------------------------------------------------------------------------
TOTAL=${#METAPKGS[@]}
info "Installation Summary: $SUCCESS_COUNT/$TOTAL packages successful."
if [[ ${#FAILED_PKGS[@]} -ne 0 ]]; then
    warn "The following packages failed or were missing:"
    for pkg in "${FAILED_PKGS[@]}"; do
        warn "  - $pkg"
    done
fi

exit 0

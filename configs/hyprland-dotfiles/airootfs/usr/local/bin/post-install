#!/usr/bin/env bash
# =============================================================================
# post-install (Universal GPU, SDDM-Hyprland, Speed & Cleanup)
# =============================================================================

set -euo pipefail

log()  { echo "[post-install] $*"; }
info() { log "INFO:  $*"; }
warn() { log "WARN:  $*"; }

# ---------------------------------------------------------------------------
# 1. IDENTIFY USERS (SAFETY CHECK)
# ---------------------------------------------------------------------------
# Identify the actual user created by Calamares (UID 1000)
MAIN_USER=$(getent passwd | awk -F: '$3 >= 1000 && $3 <= 1001 {print $1}' | grep -vE '(liveuser|builduser|nobody|root)' | head -n 1 || true)
MAIN_USER_HOME="/home/$MAIN_USER"

info "Verifying target environment..."
if [[ -z "$MAIN_USER" ]]; then
    log "ERROR: Primary user (UID 1000) not detected. Check Calamares logs."
elif [[ "$MAIN_USER" == "builduser" ]]; then
    log "WARNING: UID 1000 is 'builduser'. Skipping account purge to prevent lockout."
fi

# ---------------------------------------------------------------------------
# 2. THE CALAMARES & BOOT PURGE
# ---------------------------------------------------------------------------
info "Removing installer artifacts and masking redundant setup..."

# Remove Calamares and its autostart triggers
pacman -Rs --noconfirm calamares-mainstream || true
rm -f /etc/xdg/autostart/calamares* || true
rm -f /usr/share/applications/calamares.desktop || true

if [[ -n "$MAIN_USER" && "$MAIN_USER" != "builduser" ]]; then
    rm -rf "$MAIN_USER_HOME/.config/autostart/calamares"* || true
    rm -f "$MAIN_USER_HOME/Desktop/install-arch.desktop" || true
fi

# ---------------------------------------------------------------------------
# 3. LIVE SERVICE CLEANUP
# ---------------------------------------------------------------------------
info "Removing live-only services..."

# Remove live-ISO-only unit files entirely — disabling is not enough because
# etc-pacman.d-gnupg.mount mounts a tmpfs over the keyring directory,
# destroying any keys written there on every reboot.
for unit in \
    /etc/systemd/system/etc-pacman.d-gnupg.mount \
    /etc/systemd/system/pacman-init.service; do
    if [[ -f "$unit" ]]; then
        systemctl disable "$(basename "$unit")" 2>/dev/null || true
        rm -f "$unit"
        info "Removed live-only unit: $(basename "$unit")"
    fi
done

# Disable other live-ISO-only services (unit files owned by packages, so
# disable only — don't delete).
for svc in \
    reflector.service \
    reflector.timer \
    sshd.service; do
    if systemctl is-enabled "$svc" &>/dev/null; then
        info "Disabling live-only service: $svc"
        systemctl disable "$svc" || true
    fi
done

# Mask systemd-networkd — redundant alongside NetworkManager and can
# cause conflicts if both try to manage the same interface.
# Does NOT affect DNS resolution or keyring connectivity.
systemctl mask systemd-networkd.service || true
systemctl mask systemd-networkd.socket || true
systemctl mask systemd-networkd-persistent-storage.service || true

# ---------------------------------------------------------------------------
# 4. MKINITCPIO PREP
# GPU detection, module injection, modprobe config, and env vars are all
# handled by the install-gpu-drivers shellprocess which runs before this.
# Here we only: position the resume hook, clean up archiso preset, and
# restore the standard linux.preset before the final mkinitcpio -P call.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 4b. PLYMOUTH WITH BGRT THEME
# ---------------------------------------------------------------------------
info "Installing Plymouth boot splash with BGRT theme..."
if pacman -S --noconfirm --needed plymouth; then
    # Set BGRT theme — shows the UEFI firmware/manufacturer logo during boot
    plymouth-set-default-theme bgrt
    info "Plymouth BGRT theme configured."
else
    warn "Plymouth failed to install — boot splash will be skipped."
fi

# Remove archiso-specific mkinitcpio config — it is only valid on the live ISO.
# If left in place, mkinitcpio -P will attempt to build with archiso hooks
# (archiso, archiso_loop_mnt, etc.) that do not exist on the installed system.
info "Removing archiso-specific mkinitcpio config..."
rm -f /etc/mkinitcpio.conf.d/archiso.conf


# ---------------------------------------------------------------------------
# 4c. GPU DETECTION & CONFIGURATION
# Runs after archiso.conf is removed so mkinitcpio.conf changes are safe.
# Handles: packages, MODULES, HOOKS, modprobe, env vars, cmdline, services.
# ---------------------------------------------------------------------------
info "Detecting GPU hardware..."
GPU_INFO=$(lspci 2>/dev/null | grep -iE "VGA|3D|Display" || true)

if [[ -n "$GPU_INFO" ]]; then
    info "Detected GPU(s):"
    echo "$GPU_INFO" | while read -r line; do info "  $line"; done

    HAS_NVIDIA=false; HAS_AMD=false; HAS_INTEL=false; IS_HYBRID=false
    IS_OLD_NVIDIA=false; IS_OLD_AMD=false; IS_ARC=false; IS_OLD_INTEL=false

    # Set to true by DKMS-based NVIDIA generations (580xx, 470xx, 390xx).
    # When true, mkinitcpio -P is skipped in chroot and deferred to a
    # firstboot systemd service that runs after DKMS has finished building.
    DEFER_MKINITCPIO=false

    # Detect by PCI vendor ID — unambiguous, not subject to lspci name string variations.
    # 10de=NVIDIA  1002=AMD/ATI  8086=Intel
    lspci -nn 2>/dev/null | grep -iE "VGA|3D|Display" | grep -q "\[10de:" && HAS_NVIDIA=true || true
    lspci -nn 2>/dev/null | grep -iE "VGA|3D|Display" | grep -q "\[1002:" && HAS_AMD=true    || true
    lspci -nn 2>/dev/null | grep -iE "VGA|3D|Display" | grep -q "\[8086:" && HAS_INTEL=true  || true

    GPU_COUNT=0
    $HAS_NVIDIA && ((GPU_COUNT++)) || true
    $HAS_AMD    && ((GPU_COUNT++)) || true
    $HAS_INTEL  && ((GPU_COUNT++)) || true
    [[ $GPU_COUNT -gt 1 ]] && IS_HYBRID=true || true
    $IS_HYBRID && info "Hybrid GPU configuration detected." || true

    # --- GPU helpers ---
    gpu_add_modules() {
        for mod in "$@"; do
            if ! grep -q "\b${mod}\b" /etc/mkinitcpio.conf; then
                sed -i "s/^MODULES=(/MODULES=(${mod} /" /etc/mkinitcpio.conf
                info "Added module to initramfs: $mod"
            fi
        done
    }
    gpu_remove_hook() {
        sed -i "s/\b${1}\b *//g" /etc/mkinitcpio.conf
        info "Removed hook from initramfs: $1"
    }
    gpu_append_cmdline() {
        local params="$1" LIMINE_CONF=""
        [[ -f "/boot/efi/limine.conf" ]] && LIMINE_CONF="/boot/efi/limine.conf"
        [[ -f "/boot/limine.conf" ]]     && LIMINE_CONF="/boot/limine.conf"
        if [[ -n "$LIMINE_CONF" ]]; then
            sed -i "/^ *cmdline:/ s/$/ $params/" "$LIMINE_CONF"
            info "Added to bootloader cmdline: $params"
        else
            warn "limine.conf not found — could not add: $params"
        fi
    }
    gpu_append_env() { echo "$1" >> /etc/environment; info "Set environment: $1"; }
    # Write a single 'env = KEY,VALUE' line into the user's Hyprland custom env.conf
    # Idempotent — skips if the key is already present.
    gpu_append_hypr_env() {
        local _key="$1" _val="$2"
        local _env_conf="$MAIN_USER_HOME/.config/hypr/custom/env.conf"
        if [[ ! -f "$_env_conf" ]]; then
            warn "hypr env.conf not found at $_env_conf — skipping: $_key"
            return
        fi
        if ! grep -q "^env = ${_key}" "$_env_conf"; then
            echo "env = ${_key},${_val}" >> "$_env_conf"
            info "Added hypr env: ${_key}=${_val}"
        else
            info "hypr env already set: ${_key} — skipping."
        fi
    }
    # Add resume delays to hypridle.conf for NVIDIA cards.
    #
    # Root cause: nvidia-sleep.sh writes "resume" to /proc/driver/nvidia/suspend
    # and performs a VT switch back to the Wayland session.  There is a brief
    # window after that where the NVIDIA DRM/KMS device is still initialising.
    # If Hyprland's Aquamarine backend receives "dpms on" during that window it
    # hits a DRM error and crashes, producing the "recover session" prompt.
    #
    # This affects every NVIDIA generation that uses nvidia-sleep.sh (Fermi+),
    # including Turing+ with nvidia-open.  AMD and Intel do not need this fix —
    # their in-kernel DRM drivers (amdgpu/i915) complete resume synchronously
    # before userspace is notified, so there is no race window.
    #
    # Fix: insert a short sleep before each "hyprctl dispatch dpms on" in
    # after_sleep_cmd (2 s — covers cold resume from S3/S4) and on-resume
    # (1 s — covers re-enabling the display after an idle screen blank).
    # DPMS power-off is preserved; only the re-enable is delayed.
    gpu_fix_hypridle() {
        local _hypridle="$MAIN_USER_HOME/.config/hypr/hypridle.conf"
        if [[ ! -f "$_hypridle" ]]; then
            warn "hypridle.conf not found at $_hypridle — skipping dpms fix."
            return
        fi
        local _changed=false
        # after_sleep_cmd: delay dpms on after system wake from suspend/hibernate
        if grep -qE "after_sleep_cmd\s*=.*hyprctl dispatch dpms on" "$_hypridle" \
            && ! grep -qE "after_sleep_cmd\s*=.*sleep\s+[0-9].*&&.*hyprctl dispatch dpms on" "$_hypridle"; then
            sed -i '/after_sleep_cmd/s/hyprctl dispatch dpms on/sleep 2 \&\& hyprctl dispatch dpms on/' \
                "$_hypridle"
            _changed=true
            info "Added 2s delay before dpms on in after_sleep_cmd (NVIDIA resume fix)."
        fi
        # on-resume: delay dpms on when idle screen-blank is cleared by activity
        if grep -qE "on-resume\s*=.*hyprctl dispatch dpms on" "$_hypridle" \
            && ! grep -qE "on-resume\s*=.*sleep\s+[0-9].*&&.*hyprctl dispatch dpms on" "$_hypridle"; then
            sed -i '/on-resume/s/hyprctl dispatch dpms on/sleep 1 \&\& hyprctl dispatch dpms on/' \
                "$_hypridle"
            _changed=true
            info "Added 1s delay before dpms on in on-resume (NVIDIA resume fix)."
        fi
        "$_changed" \
            || info "hypridle.conf dpms delays already present or target lines not found — nothing to patch."
    }
    # Inject resume=PARTUUID=<uuid> into the bootloader cmdline so the kernel
    # can restore a hibernation (S4) image on boot.  Without this parameter the
    # resume hook placed in the initramfs never activates, even if the hook is
    # present and a swap partition exists.
    #
    # PARTUUID (GPT partition UUID) is used rather than UUID (filesystem UUID)
    # because the limine.conf template already uses PARTUUID for root=, keeping
    # the config uniform.  PARTUUID is also stable across mkswap reformats.
    #
    # Idempotent: skips injection if resume= is already present in limine.conf
    # or if no swap partition is found (e.g. swap-file-only or no-swap setups).
    inject_swap_resume() {
        local SWAP_PARTUUID=""
        SWAP_PARTUUID=$(blkid -t TYPE=swap -o export 2>/dev/null \
            | grep '^PARTUUID=' | head -1 | cut -d= -f2)
        if [[ -z "$SWAP_PARTUUID" ]]; then
            info "No swap partition found — skipping resume= cmdline injection."
            return
        fi
        local LIMINE_CONF=""
        [[ -f "/boot/efi/limine.conf" ]] && LIMINE_CONF="/boot/efi/limine.conf"
        [[ -f "/boot/limine.conf" ]]     && LIMINE_CONF="/boot/limine.conf"
        if [[ -n "$LIMINE_CONF" ]] && grep -q '\bresume=' "$LIMINE_CONF" 2>/dev/null; then
            info "resume= already present in limine.conf — skipping."
            return
        fi
        gpu_append_cmdline "resume=PARTUUID=$SWAP_PARTUUID"
        info "Hibernation resume= set to swap PARTUUID=$SWAP_PARTUUID."
    }

    # Sync db before installing
    pacman -Sy 2>/dev/null || warn "pacman -Sy failed — using cached db."

    # --- NVIDIA ---
    configure_nvidia() {
        local PCI_LINE PCI_ID PCI_DEC
        PCI_LINE=$(lspci -nn 2>/dev/null | grep -iE "NVIDIA|GeForce|Quadro|Tesla" | head -1)
        PCI_ID=$(echo "$PCI_LINE" | grep -oE '\[10de:[0-9a-fA-F]{4}\]' | tail -1                  | grep -oE '[0-9a-fA-F]{4}' | tail -1 || echo "0000")
        PCI_DEC=$((16#$PCI_ID))
        info "NVIDIA PCI ID: 0x$PCI_ID ($PCI_DEC)"

        if [[ $PCI_DEC -ge 7684 ]]; then
            # 0x1E04+ = Turing and newer (RTX 2060+, 30xx, 40xx, 50xx)
            # nvidia-open is the official open source kernel module (packages installed by install-gpu-drivers)
            gpu_remove_hook kms
            gpu_add_modules nvidia nvidia_modeset nvidia_uvm nvidia_drm
            mkdir -p /etc/modprobe.d
            cat > /etc/modprobe.d/nvidia.conf << 'NVIDIAEOF'
options nvidia-drm modeset=1 fbdev=1
options nvidia NVreg_PreserveVideoMemoryAllocations=1
options nvidia NVreg_TemporaryFilePath=/var/tmp
NVIDIAEOF
            gpu_append_cmdline "nvidia_drm.modeset=1"
            for svc in nvidia-suspend.service nvidia-hibernate.service nvidia-resume.service; do
                systemctl enable "$svc" 2>/dev/null && info "Enabled $svc" || warn "$svc not found."
            done
            systemctl enable nvidia-powerd.service 2>/dev/null || true
            # Write NVIDIA Wayland env vars into the user's hypr custom env.conf
            if [[ -n "$MAIN_USER" ]]; then
                printf '\n# NVIDIA Wayland — added by post-install\n' \
                    >> "$MAIN_USER_HOME/.config/hypr/custom/env.conf" 2>/dev/null || true
                gpu_append_hypr_env "LIBVA_DRIVER_NAME"            "nvidia"
                gpu_append_hypr_env "GBM_BACKEND"                  "nvidia-drm"
                gpu_append_hypr_env "__GLX_VENDOR_LIBRARY_NAME"    "nvidia"
                gpu_append_hypr_env "NVD_BACKEND"                  "direct"
                gpu_append_hypr_env "WLR_NO_HARDWARE_CURSORS"      "1"
            fi
            info "NVIDIA Turing+ configured (nvidia-open)."
            [[ -n "$MAIN_USER" ]] && gpu_fix_hypridle

        elif [[ $PCI_DEC -ge 4928 ]]; then
            # 0x1340-0x1E03 = Maxwell through Volta (GTX 900, GTX 1000, Titan V)
            # Dropped from mainline nvidia — uses nvidia-580xx-dkms
            gpu_remove_hook kms
            gpu_add_modules nvidia nvidia_modeset nvidia_uvm nvidia_drm
            mkdir -p /etc/modprobe.d
            cat > /etc/modprobe.d/nvidia.conf << 'NVIDIAEOF'
options nvidia-drm modeset=1 fbdev=1
options nvidia NVreg_PreserveVideoMemoryAllocations=1
options nvidia NVreg_TemporaryFilePath=/var/tmp
NVIDIAEOF
            gpu_append_cmdline "nvidia_drm.modeset=1"
            for svc in nvidia-suspend.service nvidia-hibernate.service nvidia-resume.service; do
                systemctl enable "$svc" 2>/dev/null && info "Enabled $svc" || warn "$svc not found."
            done
            systemctl enable nvidia-powerd.service 2>/dev/null || true
            # Write NVIDIA Wayland env vars into the user's hypr custom env.conf
            if [[ -n "$MAIN_USER" ]]; then
                printf '\n# NVIDIA Wayland — added by post-install\n' \
                    >> "$MAIN_USER_HOME/.config/hypr/custom/env.conf" 2>/dev/null || true
                gpu_append_hypr_env "LIBVA_DRIVER_NAME"            "nvidia"
                gpu_append_hypr_env "GBM_BACKEND"                  "nvidia-drm"
                gpu_append_hypr_env "__GLX_VENDOR_LIBRARY_NAME"    "nvidia"
                gpu_append_hypr_env "NVD_BACKEND"                  "direct"
                gpu_append_hypr_env "WLR_NO_HARDWARE_CURSORS"      "1"
            fi
            info "NVIDIA Maxwell-Volta (GTX 900/1000/Titan V) configured (nvidia-580xx-dkms)."
            [[ -n "$MAIN_USER" ]] && gpu_fix_hypridle
            DEFER_MKINITCPIO=true

        elif [[ $PCI_DEC -ge 4032 ]]; then
            # Kepler — 470xx installed by install-gpu-drivers if successful
            gpu_remove_hook kms
            gpu_add_modules nvidia nvidia_modeset nvidia_uvm nvidia_drm
            cat > /etc/modprobe.d/nvidia.conf << 'NVIDIAEOF'
options nvidia-drm modeset=1 fbdev=1
options nvidia NVreg_PreserveVideoMemoryAllocations=1
options nvidia NVreg_TemporaryFilePath=/var/tmp
NVIDIAEOF
            gpu_append_cmdline "nvidia_drm.modeset=1"
            for svc in nvidia-suspend.service nvidia-hibernate.service nvidia-resume.service; do
                systemctl enable "$svc" 2>/dev/null && info "Enabled $svc" || warn "$svc not found."
            done
            # Write NVIDIA Wayland env vars (NVD_BACKEND not supported on 470xx)
            if [[ -n "$MAIN_USER" ]]; then
                printf '\n# NVIDIA Wayland — added by post-install\n' \
                    >> "$MAIN_USER_HOME/.config/hypr/custom/env.conf" 2>/dev/null || true
                gpu_append_hypr_env "LIBVA_DRIVER_NAME"            "nvidia"
                gpu_append_hypr_env "GBM_BACKEND"                  "nvidia-drm"
                gpu_append_hypr_env "__GLX_VENDOR_LIBRARY_NAME"    "nvidia"
                gpu_append_hypr_env "WLR_NO_HARDWARE_CURSORS"      "1"
            fi
            info "NVIDIA Kepler configured."
            [[ -n "$MAIN_USER" ]] && gpu_fix_hypridle
            DEFER_MKINITCPIO=true

        elif [[ $PCI_DEC -ge 1728 ]]; then
            # Fermi — 390xx installed by install-gpu-drivers if successful
            gpu_remove_hook kms
            gpu_add_modules nvidia nvidia_modeset nvidia_uvm nvidia_drm
            cat > /etc/modprobe.d/nvidia.conf << 'NVIDIAEOF'
options nvidia-drm modeset=1 fbdev=1
options nvidia NVreg_PreserveVideoMemoryAllocations=1
options nvidia NVreg_TemporaryFilePath=/var/tmp
NVIDIAEOF
            gpu_append_cmdline "nvidia_drm.modeset=1"
            for svc in nvidia-suspend.service nvidia-hibernate.service nvidia-resume.service; do
                systemctl enable "$svc" 2>/dev/null && info "Enabled $svc" || warn "$svc not found."
            done
            # Write NVIDIA Wayland env vars (NVD_BACKEND not supported on 390xx)
            if [[ -n "$MAIN_USER" ]]; then
                printf '\n# NVIDIA Wayland — added by post-install\n' \
                    >> "$MAIN_USER_HOME/.config/hypr/custom/env.conf" 2>/dev/null || true
                gpu_append_hypr_env "LIBVA_DRIVER_NAME"            "nvidia"
                gpu_append_hypr_env "GBM_BACKEND"                  "nvidia-drm"
                gpu_append_hypr_env "__GLX_VENDOR_LIBRARY_NAME"    "nvidia"
                gpu_append_hypr_env "WLR_NO_HARDWARE_CURSORS"      "1"
            fi
            info "NVIDIA Fermi configured."
            [[ -n "$MAIN_USER" ]] && gpu_fix_hypridle
            DEFER_MKINITCPIO=true

        else
            # Pre-Fermi — nouveau (no config changes needed, kms hook stays)
            info "Pre-Fermi NVIDIA — using nouveau (kms hook kept)."
        fi
    }

    # --- AMD ---
    configure_amd() {
        # Safety guard — only proceed if an AMD GPU was actually detected
        if ! $HAS_AMD; then
            warn "configure_amd called without AMD GPU present — skipping."
            return 0
        fi
        info "Configuring AMD GPU..."
        local AMD_ID AMD_DEC
        AMD_ID=$(lspci -nn 2>/dev/null | grep -iE "VGA|3D|Display" | grep "1002:"                  | grep -oE "1002:[0-9a-fA-F]{4}" | head -1 | cut -d: -f2 || echo "ffff")
        AMD_DEC=$((16#${AMD_ID:-ffff}))
        info "AMD GPU PCI device ID: 0x${AMD_ID} (${AMD_DEC})"
        [[ $AMD_DEC -lt 26112 ]] && IS_OLD_AMD=true || true
        local AMD_NAME
        AMD_NAME=$(lspci 2>/dev/null | grep -iE "VGA|3D|Display" | grep -i "AMD\|ATI\|Radeon" | head -1)
        echo "$AMD_NAME" | grep -iqE "\bHD [2-6][0-9]{3}\b|\bRS[0-9]+\b|\bRV[0-9]+\b|\bR[67][0-9]{2}\b"             && IS_OLD_AMD=true || true
        if lspci 2>/dev/null | grep -iqE "Navi 4[0-9]|RX 9[0-9]{3}|gfx12"; then
            info "RDNA 4 explicitly detected — forcing modern AMD path."; IS_OLD_AMD=false
        fi

        if $IS_OLD_AMD; then
            info "Pre-GCN AMD — installing amdgpu+radeon."
            mkdir -p /etc/modprobe.d
            cat > /etc/modprobe.d/amdgpu.conf << 'AMDEOF'
options amdgpu si_support=1
options amdgpu cik_support=1
options radeon si_support=0
options radeon cik_support=0
AMDEOF
            gpu_add_modules amdgpu radeon
            gpu_append_cmdline "amdgpu.si_support=1 amdgpu.cik_support=1"
        else
            info "GCN/RDNA AMD — installing amdgpu."
            gpu_add_modules amdgpu
            gpu_append_cmdline "amdgpu.modeset=1"
            if lspci | grep -qiE "RX 9[0-9]{3}|Navi 4[0-9]|gfx1[2-9][0-9]{2}"; then
                info "RDNA 4 detected — adding amdgpu.sg_display=0 and mem_sleep_default=deep."
                gpu_append_cmdline "amdgpu.sg_display=0"
                # Force S3 (deep) suspend instead of s2idle.
                # s2idle is broken on Navi 48 through at least kernel 6.17.x — systems
                # that default to s2idle (common on modern UEFI) will hang or crash on
                # resume.  S3 deep sleep has been stable since kernel 6.15.2 / 6.16.8.
                gpu_append_cmdline "mem_sleep_default=deep"
            fi
        fi
        # NOTE: AMD env vars intentionally not set globally in /etc/environment
        # WLR_RENDERER, AMD_VULKAN_ICD, LIBVA_DRIVER_NAME can conflict with
        # Quickshell and Hyprland on modern RDNA hardware — defaults work correctly.
        # Set per-app in ~/.config/hypr/hyprland/env.conf if needed.
        info "AMD configured."
    }

    # --- INTEL ---
    configure_intel() {
        info "Configuring Intel GPU..."
        local INTEL_DEV
        INTEL_DEV=$(lspci 2>/dev/null | grep -iE "Intel.*(Graphics|UHD|HD|Iris|Arc)" | head -1)
        echo "$INTEL_DEV" | grep -iqE "Arc|Xe|A[3-7][0-9]{2}" && IS_ARC=true || true
        local INTEL_ID INTEL_DEC
        INTEL_ID=$(lspci -nn 2>/dev/null | grep -iE "Intel.*Graphics"                    | grep -oE '8086:[0-9a-fA-F]{4}' | head -1 | cut -d: -f2 || echo "ffff")
        INTEL_DEC=$((16#${INTEL_ID:-ffff}))
        [[ $INTEL_DEC -lt 256 ]] && IS_OLD_INTEL=true || true

        if $IS_ARC; then
            info "Intel Arc — installing Arc drivers."
            gpu_add_modules xe
            # LIBVA_DRIVER_NAME set in env.conf by dotfiles
        elif $IS_OLD_INTEL; then
            info "Pre-Sandy Bridge Intel — installing xf86-video-intel."
            gpu_add_modules i915
        else
            info "Sandy Bridge+ Intel — installing i915/media-driver."
            gpu_add_modules i915
            if ! $IS_HYBRID; then gpu_append_cmdline "i915.modeset=1"; fi
            # LIBVA_DRIVER_NAME set in env.conf by dotfiles
        fi
        info "Intel configured."
    }

    # --- PRIME ---
    configure_prime() {
        info "Configuring PRIME hybrid GPU..."
        if $HAS_NVIDIA && $HAS_INTEL; then
            gpu_add_modules i915; gpu_append_cmdline "i915.modeset=1"
            # PRIME env vars set in env.conf by dotfiles, not system-wide
        elif $HAS_NVIDIA && $HAS_AMD; then
            gpu_add_modules amdgpu
            # PRIME env vars set in env.conf by dotfiles, not system-wide
        elif $HAS_AMD && $HAS_INTEL; then
            : # DRI_PRIME set per-app, not system-wide
        fi

        # Set AQ_DRM_DEVICES to the stable by-path PCI symlink for the NVIDIA card.
        # card0/card1 enumeration order is non-deterministic across reboots; the
        # by-path symlink is stable because it encodes the physical PCIe slot.
        # lspci -D is safe in a Calamares chroot — /proc is bind-mounted from the host.
        if $HAS_NVIDIA && [[ -n "$MAIN_USER" ]]; then
            local NVIDIA_PCIADDR
            NVIDIA_PCIADDR=$(lspci -D 2>/dev/null \
                | grep -iE "NVIDIA|GeForce|Quadro|Tesla" \
                | head -1 | awk '{print $1}')
            if [[ -n "$NVIDIA_PCIADDR" ]]; then
                local AQ_PATH="/dev/dri/by-path/pci-${NVIDIA_PCIADDR}-card"
                printf '\n# PRIME: stable NVIDIA DRM device — added by post-install\n' \
                    >> "$MAIN_USER_HOME/.config/hypr/custom/env.conf" 2>/dev/null || true
                gpu_append_hypr_env "AQ_DRM_DEVICES" "$AQ_PATH"
            else
                warn "Could not resolve NVIDIA PCI address — AQ_DRM_DEVICES not set."
            fi
        fi

        info "PRIME configured."
    }

    # --- SLEEP ---
    configure_sleep() {
        if [[ -f /sys/power/mem_sleep ]]; then
            local MEM_SLEEP; MEM_SLEEP=$(cat /sys/power/mem_sleep)
            info "Available sleep modes: $MEM_SLEEP"
            if echo "$MEM_SLEEP" | grep -q "deep"; then
                gpu_append_cmdline "mem_sleep_default=deep"; info "S3 deep sleep enabled."
            else
                info "S3 not available — using Modern Standby (s2idle)."
            fi
        fi
    }

    # Run — Intel first so i915 appears before NVIDIA in MODULES
    $HAS_INTEL  && configure_intel  || true
    $HAS_AMD    && configure_amd    || true
    $HAS_NVIDIA && configure_nvidia || true
    $IS_HYBRID  && configure_prime  || true
    configure_sleep
    inject_swap_resume

    info "GPU configuration complete. Intel=$HAS_INTEL AMD=$HAS_AMD NVIDIA=$HAS_NVIDIA Hybrid=$IS_HYBRID"
else
    warn "No GPU detected via lspci — skipping GPU configuration."
fi

# Restore a standard installed-system mkinitcpio preset so mkinitcpio -P
# produces a normal default + fallback initramfs from /etc/mkinitcpio.conf.
cat > /etc/mkinitcpio.d/linux.preset << 'PRESET'
PRESETS=('default' 'fallback')
ALL_kver='/boot/vmlinuz-linux'
default_config='/etc/mkinitcpio.conf'
default_image='/boot/initramfs-linux.img'
fallback_config='/etc/mkinitcpio.conf'
fallback_image='/boot/initramfs-linux-fallback.img'
fallback_options='-S autodetect'
PRESET

# ---------------------------------------------------------------------------
# ENSURE VALID MACHINE-ID (required by limine-mkinitcpio-hook)
# ---------------------------------------------------------------------------
# mkarchiso sets /etc/machine-id to "uninitialized" (13 chars) for systemd
# first-boot semantics.  limine-mkinitcpio-hook requires a valid 32-char hex
# machine-id to place kernel/initramfs on the EFI partition.  Calamares'
# machineid module should have generated one, but verify and fix if needed.
if ! grep -qE '^[0-9a-f]{32}$' /etc/machine-id 2>/dev/null; then
    warn "Invalid or missing machine-id — generating one..."
    systemd-machine-id-setup 2>/dev/null || \
        printf '%s\n' "$(cat /proc/sys/kernel/random/uuid | tr -d '-')" > /etc/machine-id
    info "Machine-id set to: $(cat /etc/machine-id)"
fi

# ---------------------------------------------------------------------------
# INSTALL SNAPPER + LIMINE AUR PACKAGES (before mkinitcpio -P)
# ---------------------------------------------------------------------------
# These can't be in packages.x86_64 (limine-mkinitcpio-hook breaks archiso
# build chroot) and can't be in packages.conf install section (no db sync
# available).  We install them here via yay which handles AUR + db sync.
#
# IMPORTANT: limine-mkinitcpio-hook must be installed BEFORE mkinitcpio -P
# so the hook can manage kernel/initramfs placement on the EFI partition and
# generate proper //linux sub-entries in limine.conf.
if command -v yay &>/dev/null; then
    info "Installing snapper and limine integration packages..."
    su -s /bin/bash "$MAIN_USER" -c \
        "yay -S --noconfirm --needed snapper snap-pac limine-mkinitcpio-hook limine-snapper-sync" \
        2>/dev/null || \
        pacman -S --noconfirm --needed snapper snap-pac 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# MKINITCPIO — immediate or deferred depending on GPU driver type
# ---------------------------------------------------------------------------
# DKMS drivers (580xx, 470xx, 390xx) cannot build kernel modules in a
# Calamares chroot because the running host kernel differs from the installed
# one.  Running mkinitcpio -P with missing modules produces no image at all,
# leaving the stale archiso initramfs on the EFI partition → kernel panic.
#
# For those generations we skip mkinitcpio -P entirely here and install a
# oneshot firstboot service that runs on the first real boot, by which time
# DKMS has completed and all modules exist on disk.  The service then
# triggers an automatic reboot so the user boots into the fully built
# initramfs on the second boot — transparent, no manual intervention needed.
#
# Turing+ uses nvidia-open which is a real package (not DKMS) — modules exist
# immediately, so mkinitcpio -P runs normally in chroot.

if $DEFER_MKINITCPIO; then
    info "DKMS NVIDIA driver detected — deferring mkinitcpio -P to first boot."

    cat > /etc/systemd/system/mkinitcpio-firstboot.service << 'MKINITEOF'
[Unit]
Description=Rebuild initramfs after DKMS modules are ready (first boot only)
After=dkms.service systemd-modules-load.service local-fs.target
Wants=dkms.service

[Service]
Type=oneshot
RemainAfterExit=yes
# Rebuild initramfs with all modules now present on disk
ExecStart=/usr/bin/mkinitcpio -P
# Sync kernel/initramfs to EFI partition
ExecStartPost=/bin/bash -c '\
    if command -v limine-mkinitcpio &>/dev/null; then \
        limine-mkinitcpio 2>/dev/null || true; \
    fi; \
    efi_root=""; \
    [ -d /boot/efi ] && efi_root="/boot/efi"; \
    [ -z "$efi_root" ] && [ -d /efi ] && efi_root="/efi"; \
    if [ -n "$efi_root" ]; then \
        cp -f /boot/vmlinuz-linux "$efi_root/vmlinuz-linux" || true; \
        cp -f /boot/initramfs-linux.img "$efi_root/initramfs-linux.img" || true; \
        cp -f /boot/initramfs-linux-fallback.img "$efi_root/initramfs-linux-fallback.img" || true; \
    fi'
# Disable ourselves — one-shot job done
ExecStartPost=/usr/bin/systemctl disable mkinitcpio-firstboot.service

[Install]
WantedBy=multi-user.target
MKINITEOF

    systemctl enable mkinitcpio-firstboot.service 2>/dev/null || true
    info "mkinitcpio-firstboot.service installed and enabled."

    # Deploy an autostart .desktop entry so the user gets a reboot notification
    # on their first login after the initramfs rebuild completes.
    # The script sends the notification then removes the autostart entry so it
    # never fires again.
    if [[ -n "$MAIN_USER" ]]; then
        mkdir -p "$MAIN_USER_HOME/.config/autostart"
        cat > "$MAIN_USER_HOME/.config/autostart/mkinitcpio-reboot-notify.desktop" << 'NOTIFYEOF'
[Desktop Entry]
Type=Application
Name=Initramfs Rebuild Notification
Comment=Notify user to reboot after DKMS initramfs rebuild
Exec=/bin/bash -c 'sleep 5 && notify-send --urgency=critical --icon=system-reboot "Reboot Required" "Your GPU drivers were set up in the background. Please reboot to finish the installation and apply all changes." && rm -f ~/.config/autostart/mkinitcpio-reboot-notify.desktop'
X-GNOME-Autostart-enabled=true
NoDisplay=true
NOTIFYEOF
        chown "$MAIN_USER:$MAIN_USER" \
            "$MAIN_USER_HOME/.config/autostart/mkinitcpio-reboot-notify.desktop"
        info "Reboot notification autostart deployed for $MAIN_USER."
    fi

else
    # Turing+ (nvidia-open) or non-NVIDIA: modules exist now, safe to build.
    info "Regenerating initramfs..."
    if ! mkinitcpio -P; then
        warn "mkinitcpio -P returned non-zero (limine hook issue?) — checking if images were built..."
        if [ -f /boot/initramfs-linux.img ]; then
            info "Initramfs images exist — continuing despite hook warning."
        else
            warn "Initramfs images missing — mkinitcpio truly failed."
            exit 1
        fi
    fi

    if command -v limine-mkinitcpio &>/dev/null; then
        info "Updating Limine boot entries via limine-mkinitcpio..."
        limine-mkinitcpio 2>/dev/null || warn "limine-mkinitcpio returned non-zero (may be OK in chroot)."
    fi

    if [ -d "/boot/efi" ]; then
        cp -f /boot/vmlinuz-linux       /boot/efi/ || true
        cp -f /boot/initramfs-linux.img /boot/efi/ || true
    fi
fi

# ---------------------------------------------------------------------------
# 5. SDDM THEME, WAYLAND CONFIG & BTRFS FIXES
# ---------------------------------------------------------------------------
info "Installing pixie SDDM theme..."

SDDM_THEME_DIR="/usr/share/sddm/themes/pixie"
if ping -c1 -W3 github.com &>/dev/null; then
    if git clone --depth=1 https://github.com/gregorytrentmartinjr/pixie-sddm.git "$SDDM_THEME_DIR"; then
        info "pixie SDDM theme installed successfully."
    else
        warn "Failed to clone pixie-sddm — SDDM will use default theme."
    fi
else
    warn "No network — skipping pixie SDDM theme install."
fi

info "Configuring SDDM-Hyprland and correcting fstab..."

# SDDM Wayland Handshake + pixie theme
mkdir -p /etc/sddm.conf.d
cat > /etc/sddm.conf.d/10-wayland.conf <<SDDMEOF
[General]
DisplayServer=wayland
GreeterEnvironment=QT_WAYLAND_SHELL_INTEGRATION=layer-shell

[Wayland]
CompositorCommand=start-hyprland

[Theme]
Current=pixie
SDDMEOF

# Remove the live ISO autologin config — the installed system should show
# the SDDM greeter. The live ISO uses autologin for liveuser which must not
# carry over to the installed system.
rm -f /etc/sddm.conf.d/autologin.conf
info "SDDM autologin disabled for installed system (greeter will be shown)."

# SDDM user home directory, Hyprland greeter config, and permissions
mkdir -p /var/lib/sddm/.config/hypr
cat > /var/lib/sddm/.config/hypr/hyprland.conf <<HYPREOF
monitor=,preferred,auto,1

misc {
    disable_hyprland_logo = true
    disable_splash_rendering = true
    force_default_wallpaper = 0
}

animations {
    enabled = false
}

windowrule = match:class ^(sddm-greeter-qt6)$, fullscreen on
HYPREOF
chown -R sddm:sddm /var/lib/sddm
chmod 700 /var/lib/sddm/.config
chmod 700 /var/lib/sddm/.config/hypr
chmod 600 /var/lib/sddm/.config/hypr/hyprland.conf

# Fix Btrfs subvolume naming mismatch (@ vs /@)
sed -i 's|subvol=/@|subvol=@|g' /etc/fstab || true

# ---------------------------------------------------------------------------
# 5b. SDDM BACKGROUND POLKIT SETUP
# ---------------------------------------------------------------------------
# Install the polkit helper + rules so wallpaper switches can update the
# SDDM login screen background without a password prompt
DOTFILES_REPO="/tmp/dotfiles-setup"
if [[ -d "$DOTFILES_REPO" ]]; then
    info "Installing SDDM background polkit helper..."

    HELPER_SRC="$DOTFILES_REPO/dots/.config/quickshell/ii/scripts/colors/sddm-bg-helper.sh"
    POLICY_SRC="$DOTFILES_REPO/sdata/polkit/org.illogicalimpulse.sddm-bg.policy"
    RULES_SRC="$DOTFILES_REPO/sdata/polkit/50-sddm-bg.rules"

    if [[ -f "$HELPER_SRC" ]]; then
        cp "$HELPER_SRC" /usr/local/bin/sddm-bg-helper
        chmod 755 /usr/local/bin/sddm-bg-helper
        info "sddm-bg-helper installed."
    else
        warn "sddm-bg-helper.sh not found in dotfiles repo — SDDM background updates may prompt for password."
    fi

    if [[ -f "$POLICY_SRC" ]]; then
        mkdir -p /usr/share/polkit-1/actions
        cp "$POLICY_SRC" /usr/share/polkit-1/actions/
        info "Polkit policy installed."
    fi

    if [[ -f "$RULES_SRC" ]]; then
        mkdir -p /usr/share/polkit-1/rules.d
        cp "$RULES_SRC" /usr/share/polkit-1/rules.d/
        info "Polkit rules installed."
    fi
else
    warn "/tmp/dotfiles-setup not found — skipping SDDM polkit setup."
fi

# ---------------------------------------------------------------------------
# 6. CLEANUP BUILDUSER
# ---------------------------------------------------------------------------
# Precision purge: Only remove builduser if it isn't our primary account
if id "builduser" &>/dev/null && [[ "$MAIN_USER" != "builduser" ]]; then
    info "Purging temporary build user..."
    userdel -rf builduser || true
fi

# Remove builduser sudoers immediately — builduser has been deleted above.
rm -f /etc/sudoers.d/builduser 2>/dev/null || true

# g_wheel grants %wheel passwordless sudo.  The Calamares packages module
# (Job 34) runs AFTER this script and uses yay, which calls sudo pacman
# internally.  Deleting g_wheel here would leave the user without
# passwordless sudo and yay would silently fail to install every optional
# package the user selected in the netinstall step.
#
# Instead, schedule removal via a first-boot oneshot service so g_wheel
# survives until Calamares is fully done, then gets replaced with a
# normal password-requiring wheel sudoers rule on the first boot.
info "Scheduling passwordless sudoers cleanup for first boot..."
cat > /etc/systemd/system/sudo-cleanup.service << 'SUDOCLEANEOF'
[Unit]
Description=Replace passwordless sudoers with password-required rule after installation
ConditionPathExists=/etc/sudoers.d/g_wheel
After=multi-user.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash -c 'printf "%%wheel ALL=(ALL:ALL) ALL\n" > /etc/sudoers.d/wheel && chmod 0440 /etc/sudoers.d/wheel && rm -f /etc/sudoers.d/g_wheel'
ExecStartPost=/usr/bin/systemctl disable sudo-cleanup.service

[Install]
WantedBy=multi-user.target
SUDOCLEANEOF
systemctl enable sudo-cleanup.service 2>/dev/null || true
rm -f /var/lib/pacman/db.lck 2>/dev/null || true

# ---------------------------------------------------------------------------
# 6b. PACMAN KEYRING INITIALIZATION
# ---------------------------------------------------------------------------
# pacman-key --init often fails in a chroot (no gpg-agent, limited entropy).
# Try it here as a best-effort, but the real guarantee is the first-boot
# oneshot service created below.
info "Initializing pacman keyring (best-effort in chroot)..."
pacman-key --init 2>/dev/null || true
pacman-key --populate archlinux 2>/dev/null || true

# Create a first-boot oneshot that (re-)initializes the keyring with proper
# entropy and a running gpg-agent — guaranteed to work unlike the chroot attempt.
info "Scheduling pacman keyring initialization for first boot..."
cat > /etc/systemd/system/pacman-keyring-init.service << 'KEYRINGEOF'
[Unit]
Description=Initialize pacman keyring on first boot
After=network-online.target time-sync.target
Wants=network-online.target
# Run if the keyring is missing OR empty (e.g. left over from a tmpfs mount).
# The ExecCondition check handles both cases; ConditionPathExists alone is
# not enough because an empty pubring.gpg can exist from a failed init.
ConditionPathExists=!/etc/pacman.d/gnupg/trustdb.gpg

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash -c 'rm -rf /etc/pacman.d/gnupg && pacman-key --init && pacman-key --populate archlinux && pacman-key --updatedb'
ExecStartPost=/usr/bin/systemctl disable pacman-keyring-init.service

[Install]
WantedBy=multi-user.target
KEYRINGEOF
systemctl enable pacman-keyring-init.service 2>/dev/null || true
info "Pacman keyring initialization scheduled."

# ---------------------------------------------------------------------------
# 6c. ZRAM CONFIGURATION
# ---------------------------------------------------------------------------
# zram-generator needs a config file to create compressed swap in RAM
if command -v zram-generator &>/dev/null || pacman -Q zram-generator &>/dev/null 2>&1; then
    info "Configuring zram swap..."
    cat > /etc/systemd/zram-generator.conf << 'ZRAMEOF'
[zram0]
zram-size = min(ram, 8192)
compression-algorithm = zstd
ZRAMEOF
    info "zram configured."
fi

# ---------------------------------------------------------------------------
# 6d. SYSCTL PERFORMANCE TUNING
# ---------------------------------------------------------------------------
info "Applying sysctl performance tuning..."
mkdir -p /etc/sysctl.d
cat > /etc/sysctl.d/99-performance.conf << 'SYSCTLEOF'
# Keep more data in RAM — less aggressive swapping to zram
vm.swappiness = 10

# Start flushing dirty pages earlier to avoid big write spikes
vm.dirty_background_ratio = 5
vm.dirty_ratio = 15

# Retain more dentries/inodes in cache — faster file lookups
vm.vfs_cache_pressure = 50

# Raise inotify watch limit for Quickshell file watchers
fs.inotify.max_user_watches = 524288
fs.inotify.max_user_instances = 512
SYSCTLEOF
info "sysctl tuning applied."

# ---------------------------------------------------------------------------
# 7. SERVICES, SHELL & FINAL PERMISSIONS
# ---------------------------------------------------------------------------
info "Enabling core services and finalizing user shell..."
systemctl set-default graphical.target
systemctl enable sddm.service -f

for svc in NetworkManager bluetooth; do
    systemctl enable "$svc" 2>/dev/null || true
done

if [[ -n "$MAIN_USER" ]]; then
    # Add to essential groups
    groupadd -f render
    groupadd -f video
    usermod -aG video,render,wheel "$MAIN_USER"

    # Change user shell to Zsh if installed
    if [ -f /usr/bin/zsh ]; then
        info "Setting default shell to Zsh for $MAIN_USER..."
        chsh -s /usr/bin/zsh "$MAIN_USER" || true
    fi

    # Remove quickshell first-run sentinel copied from skel so the installed
    # user sees the welcome message on their first login.
    rm -f "$MAIN_USER_HOME/.local/state/quickshell/user/first_run.txt"

    # Final ownership guarantee
    chown -R "$MAIN_USER:$MAIN_USER" "$MAIN_USER_HOME"

    # Add hyprpolkitagent autostart if not already present in dotfiles
    EXECS_CONF="$MAIN_USER_HOME/.config/hypr/custom/execs.conf"
    if [[ -f "$EXECS_CONF" ]] && ! grep -q "hyprpolkitagent" "$EXECS_CONF"; then
        info "Adding hyprpolkitagent to Hyprland autostart..."
        echo "exec-once = hyprpolkitagent" >> "$EXECS_CONF"
    elif [[ ! -f "$EXECS_CONF" ]]; then
        warn "Could not find $EXECS_CONF — hyprpolkitagent will not autostart."
    fi

    # ---------------------------------------------------------------------------
    # Deploy dotfiles-first-login so it runs on first login via profile.d
    # ---------------------------------------------------------------------------
    if [[ -f /usr/local/bin/dotfiles-first-login ]]; then
        info "Deploying dotfiles-first-login to profile.d..."
        cp /usr/local/bin/dotfiles-first-login /etc/profile.d/dotfiles-first-login.sh
        chmod +x /etc/profile.d/dotfiles-first-login.sh
    else
        warn "dotfiles-first-login not found in /usr/local/bin — skipping profile.d deploy."
    fi

    # ---------------------------------------------------------------------------
    # Fix Nautilus home directory and set as default file manager
    # ---------------------------------------------------------------------------
    info "Configuring Nautilus as default file manager..."

    # Generate XDG user directories (creates ~/Downloads, ~/Documents etc.)
    # Run as the real user so paths resolve correctly
    su -s /bin/bash "$MAIN_USER" -c "xdg-user-dirs-update --force" || true

    # Set Nautilus as default file manager
    su -s /bin/bash "$MAIN_USER" -c "xdg-mime default org.gnome.Nautilus.desktop inode/directory" || true

    # Set Loupe as default image viewer for all common image types
    IMAGE_TYPES=(
        image/png image/jpeg image/gif image/bmp image/webp image/tiff
        image/svg+xml image/svg+xml-compressed image/x-icon image/vnd.microsoft.icon
        image/avif image/heif image/heic image/jxl
    )
    for mime in "${IMAGE_TYPES[@]}"; do
        su -s /bin/bash "$MAIN_USER" -c "xdg-mime default org.gnome.Loupe.desktop $mime" || true
    done
    info "Loupe set as default image viewer."

    # Compile dconf system database so dark mode is default before first login
    dconf update 2>/dev/null || true

    # Set gsettings defaults — dark mode + Nautilus preferences
    su -s /bin/bash "$MAIN_USER" -c "
        export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/\$(id -u '$MAIN_USER')/bus
        gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
        gsettings set org.gnome.desktop.interface gtk-theme 'adw-gtk3-dark' 2>/dev/null || true
        gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark' 2>/dev/null || true
        gsettings set org.gnome.desktop.interface font-name 'Google Sans Flex Medium 11 @opsz=11,wght=500' 2>/dev/null || true
        gsettings set org.gnome.desktop.interface cursor-theme 'Bibata-Modern-Classic' 2>/dev/null || true
        gsettings set org.gnome.desktop.interface cursor-size 24 2>/dev/null || true
        gsettings set org.gnome.nautilus.preferences default-folder-viewer 'icon-view' 2>/dev/null || true
        gsettings set org.gnome.nautilus.preferences show-hidden-files false 2>/dev/null || true
    " || true

    # ---------------------------------------------------------------------------
    # Use pre-baked Python venv from skel, or create one if missing
    # ---------------------------------------------------------------------------
    VENV_PATH="$MAIN_USER_HOME/.local/state/quickshell/.venv"

    if [[ -f "$VENV_PATH/bin/python" ]]; then
        # Venv was pre-baked into skel by build.sh --refresh — just fix shebangs
        info "Pre-baked Python venv found — fixing paths for $MAIN_USER..."
        find "$VENV_PATH/bin" -type f -exec \
            sed -i "1s|#!/home/SKEL_USER/|#!$MAIN_USER_HOME/|" {} + 2>/dev/null || true
        # Fix VIRTUAL_ENV path in activate scripts (not just shebangs)
        for _activate in "$VENV_PATH/bin/activate" \
                         "$VENV_PATH/bin/activate.csh" \
                         "$VENV_PATH/bin/activate.fish"; do
            [[ -f "$_activate" ]] && \
                sed -i "s|/home/SKEL_USER/|$MAIN_USER_HOME/|g" "$_activate"
        done
        # Fix pyvenv.cfg home path
        sed -i "s|/home/SKEL_USER/|$MAIN_USER_HOME/|g" "$VENV_PATH/pyvenv.cfg" 2>/dev/null || true
        chown -R "$MAIN_USER:$MAIN_USER" "$VENV_PATH"
        info "Python venv ready (pre-baked)."
    else
        # Fallback: create venv from scratch (slower, ~2-5 min)
        REQUIREMENTS="/tmp/dotfiles-setup/sdata/uv/requirements.txt"
        if [[ ! -f "$REQUIREMENTS" ]]; then
            REQUIREMENTS="$MAIN_USER_HOME/.local/share/quickshell/sdata/uv/requirements.txt"
        fi

        if command -v uv &>/dev/null && [[ -f "$REQUIREMENTS" ]]; then
            info "No pre-baked venv — creating Python venv at $VENV_PATH..."
            mkdir -p "$MAIN_USER_HOME/.local/state/quickshell"
            chown "$MAIN_USER:$MAIN_USER" "$MAIN_USER_HOME/.local/state/quickshell"

            VENV_HELPER="/tmp/create-venv-$MAIN_USER.sh"
            cat > "$VENV_HELPER" << VENVEOF
#!/usr/bin/env bash
uv venv "$VENV_PATH"
uv pip install --python "$VENV_PATH/bin/python" -r "$REQUIREMENTS"
VENVEOF
            chmod 755 "$VENV_HELPER"
            chown "$MAIN_USER:$MAIN_USER" "$VENV_HELPER"

            if su -s /bin/bash "$MAIN_USER" -c "bash $VENV_HELPER" 2>&1; then
                chown -R "$MAIN_USER:$MAIN_USER" "$VENV_PATH" 2>/dev/null || true
                info "Python venv created successfully."
            else
                warn "venv creation failed — will retry on first login"
            fi
            rm -f "$VENV_HELPER"
        else
            warn "uv or requirements.txt not found — venv will be created on first login"
        fi
    fi

    # Rebuild font cache as the target user so custom fonts are found
    info "Rebuilding font cache for $MAIN_USER..."
    su -s /bin/bash "$MAIN_USER" -c "fc-cache -fv" 2>/dev/null || true

    # Generate initial matugen color scheme from default wallpaper
    # This ensures theming works correctly on first login without requiring
    # the user to manually set a wallpaper
    DEFAULT_WALL="$MAIN_USER_HOME/.config/quickshell/ii/assets/images/default_wallpaper.png"
    SWITCHWALL="$MAIN_USER_HOME/.config/quickshell/ii/scripts/colors/switchwall.sh"
    VENV_PATH="$MAIN_USER_HOME/.local/state/quickshell/.venv"

    if [[ -f "$DEFAULT_WALL" ]] && command -v matugen &>/dev/null; then
        info "Generating initial Material You colors from default wallpaper..."
        mkdir -p "$MAIN_USER_HOME/.local/state/quickshell/user/generated/wallpaper"
        chown -R "$MAIN_USER:$MAIN_USER" "$MAIN_USER_HOME/.local/state"

        # Run full switchwall pipeline if venv is ready — generates all color files
        # including material_colors.scss and terminal/kitty-theme.conf
        if [[ -f "$VENV_PATH/bin/activate" ]] && [[ -f "$SWITCHWALL" ]]; then
            info "Running full color pipeline via switchwall.sh..."
            SW_HELPER="/tmp/switchwall-$MAIN_USER.sh"
            cat > "$SW_HELPER" << SWEOF
#!/usr/bin/env bash
export ILLOGICAL_IMPULSE_VIRTUAL_ENV="$VENV_PATH"
bash "$SWITCHWALL" --image "$DEFAULT_WALL" --mode dark
SWEOF
            chmod 755 "$SW_HELPER"
            chown "$MAIN_USER:$MAIN_USER" "$SW_HELPER"
            su -s /bin/bash "$MAIN_USER" -c "bash $SW_HELPER" 2>&1 ||                 warn "switchwall failed — falling back to matugen only"
            rm -f "$SW_HELPER"
        else
            # Fallback: just run matugen for the basic color templates
            su -s /bin/bash "$MAIN_USER" -c "matugen image $DEFAULT_WALL" 2>/dev/null || true
            warn "Venv not ready — terminal colors will be set on first login"
        fi
        info "Initial color scheme generated."
    else
        warn "Default wallpaper or matugen not found — skipping initial color generation."
    fi

    # Create the marker file so the first-login script knows to run
    touch "$MAIN_USER_HOME/.dotfiles-pending-user-setup"
    chown "$MAIN_USER:$MAIN_USER" "$MAIN_USER_HOME/.dotfiles-pending-user-setup"
    info "Created first-login marker for $MAIN_USER."

    # Preserve the cloned dotfiles repo so first-login script can find it
    if [[ -d /tmp/dotfiles-setup ]]; then
        info "Preserving dotfiles repo to $MAIN_USER_HOME/dots-hyprland..."
        cp -a /tmp/dotfiles-setup "$MAIN_USER_HOME/dots-hyprland"
        chown -R "$MAIN_USER:$MAIN_USER" "$MAIN_USER_HOME/dots-hyprland"
    else
        warn "/tmp/dotfiles-setup not found — first-login uv venv setup may be skipped."
    fi
fi
# ---------------------------------------------------------------------------
# KILL-FPRINTD SERVICE
# ---------------------------------------------------------------------------
# Kills fprintd before sleep to prevent fingerprint reader issues
info "Creating kill-fprintd service..."
cat > /etc/systemd/system/kill-fprintd.service << 'FPRINTEOF'
[Unit]
Description=Kill fprintd before sleep
Before=sleep.target

[Service]
ExecStart=killall fprintd

[Install]
WantedBy=sleep.target
FPRINTEOF
systemctl enable kill-fprintd.service 2>/dev/null || true

# ---------------------------------------------------------------------------
# SNAPPER + LIMINE-SNAPPER-SYNC SETUP
# ---------------------------------------------------------------------------
# Detect btrfs — findmnt may not work inside a Calamares chroot because
# /proc/self/mountinfo reflects the host, not the chrooted root.  Fall back
# to checking /etc/fstab (written by Calamares before post-install runs) or
# testing with the btrfs tool directly.
_root_is_btrfs=false
if findmnt -n -o FSTYPE / 2>/dev/null | grep -q btrfs; then
    _root_is_btrfs=true
elif grep -qE '^\s*[^#]\S+\s+/\s+btrfs\s' /etc/fstab 2>/dev/null; then
    _root_is_btrfs=true
elif btrfs filesystem usage / &>/dev/null; then
    _root_is_btrfs=true
fi

if ! $_root_is_btrfs; then
    warn "Root filesystem is NOT btrfs — skipping snapper configuration."
fi

if $_root_is_btrfs; then
    info "Btrfs detected on / — preparing snapper for firstboot setup..."

    # IMPORTANT: We do NOT create /.snapshots, write config files, or call
    # any snapper commands in this chroot.  snapper create-config sets up
    # internal btrfs metadata that manual file writes cannot replicate,
    # causing "Snapshot.cc reading failed" errors.  All snapper setup is
    # deferred to snapper-firstboot which runs on the real booted system.

    # Remove any /.snapshots that Calamares may have created as a plain
    # directory — snapper create-config needs it to NOT exist.
    if [[ -d "/.snapshots" ]] && ! btrfs subvolume show /.snapshots &>/dev/null; then
        info "Removing plain /.snapshots directory (snapper will recreate it)..."
        rm -rf /.snapshots 2>/dev/null || true
    elif btrfs subvolume show /.snapshots &>/dev/null; then
        info "Removing pre-existing /.snapshots subvolume (snapper will recreate it)..."
        btrfs subvolume delete /.snapshots 2>/dev/null || true
    fi

    # Deploy limine-snapper-sync config
    if command -v limine-snapper-sync &>/dev/null; then
        info "Configuring limine-snapper-sync..."
        cat > /etc/limine-snapper-sync.conf << 'LSSCONF'
LIMIT_USAGE_PERCENT=85
MAX_SNAPSHOT_ENTRIES=8
ROOT_SUBVOLUME_PATH="/@"
ROOT_SNAPSHOTS_PATH="/@/.snapshots"
RESTORE_METHOD=replace
SET_SNAPSHOT_AS_DEFAULT=no
SNAPSHOT_FORMAT_CHOICE=2
COMMANDS_BEFORE_SAVE="limine-reset-enroll"
COMMANDS_AFTER_SAVE="limine-enroll-config"
NOTIFICATION_ICON="/usr/share/icons/hicolor/128x128/apps/LimineSnapperSync.png"
LSSCONF

        # Tell limine-snapper-sync which snapper config to use, so it never
        # tries to auto-create one via "snapper create-config" (which deletes
        # existing configs as a side effect).
        mkdir -p /etc/default
        cat > /etc/default/limine << 'LIMINEDEF'
SNAPPER_CONFIG_NAME=root
LIMINEDEF

        info "limine-snapper-sync config deployed."
    else
        warn "limine-snapper-sync not found — skipping Limine snapshot integration."
    fi

    # NOTE: snapper timers and limine-snapper-sync are NOT enabled here.
    # They are enabled by snapper-firstboot on first boot AFTER configs are
    # fully set up.  Enabling them here causes a race condition where
    # snapperd starts via D-Bus activation before configs exist, deleting them.

    # --- Firstboot service ---
    # All snapper setup happens on first boot where D-Bus, btrfs, and the
    # real filesystem are fully available.  snapper create-config sets up
    # internal btrfs metadata that manual config file writes cannot replicate.
    cat > /etc/systemd/system/snapper-init.service << 'SNAPPERUNITEOF'
[Unit]
Description=Initialize snapper configs and create first snapshot
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/snapper-firstboot

[Install]
WantedBy=multi-user.target
SNAPPERUNITEOF

    cat > /usr/local/bin/snapper-firstboot << 'FIRSTBOOTEOF'
#!/usr/bin/env bash
set -euo pipefail
log() { echo "[snapper-firstboot] $*"; }

# --- Root config via snapper create-config ---
if snapper list-configs 2>/dev/null | grep -q "^root"; then
    log "Root config already exists."
elif [[ -f /etc/snapper/configs/root ]]; then
    # Config file exists but snapper doesn't recognize it (stale manual config).
    # Remove it so create-config can start fresh.
    log "Removing stale root config..."
    rm -f /etc/snapper/configs/root
    if btrfs subvolume show /.snapshots &>/dev/null; then
        btrfs subvolume delete /.snapshots 2>/dev/null || true
    fi
    rm -rf /.snapshots 2>/dev/null || true
    log "Creating root config via snapper create-config..."
    snapper create-config / || log "WARN: snapper create-config / failed."
else
    # Clean slate — let snapper create everything
    if btrfs subvolume show /.snapshots &>/dev/null; then
        btrfs subvolume delete /.snapshots 2>/dev/null || true
    fi
    rm -rf /.snapshots 2>/dev/null || true
    log "Creating root config via snapper create-config..."
    snapper create-config / || log "WARN: snapper create-config / failed."
fi

# Customize root config
if [[ -f /etc/snapper/configs/root ]]; then
    sed -i 's/^TIMELINE_CREATE=.*/TIMELINE_CREATE="yes"/' /etc/snapper/configs/root
    sed -i 's/^TIMELINE_LIMIT_HOURLY=.*/TIMELINE_LIMIT_HOURLY="5"/' /etc/snapper/configs/root
    sed -i 's/^TIMELINE_LIMIT_DAILY=.*/TIMELINE_LIMIT_DAILY="7"/' /etc/snapper/configs/root
    # Set ALLOW_USERS to the first non-system user
    _user=$(getent passwd | awk -F: '$3 >= 1000 && $3 <= 1100 {print $1}' | grep -vE '(nobody)' | head -n1 || true)
    if [[ -n "$_user" ]]; then
        sed -i "s/^ALLOW_USERS=.*/ALLOW_USERS=\"$_user\"/" /etc/snapper/configs/root
    fi
    log "Root config customized."
fi

# --- Home config ---
if findmnt -n -o FSTYPE /home 2>/dev/null | grep -q btrfs; then
    if ! snapper list-configs 2>/dev/null | grep -q "^home"; then
        log "Creating home config via snapper create-config..."
        snapper -c home create-config /home 2>/dev/null || \
            log "WARN: snapper create-config /home failed."
    fi
fi

# --- Initial snapshot ---
if snapper -c root list 2>/dev/null | grep -q "Fresh install"; then
    log "Fresh install snapshot already exists."
else
    log "Creating initial 'Fresh install' snapshot..."
    snapper -c root create --description "Fresh install" 2>/dev/null || \
        log "WARN: Could not create initial snapshot."
fi

# --- Enable snapper timers NOW that configs are set up ---
log "Enabling snapper timers and limine-snapper-sync..."
systemctl enable --now snapper-timeline.timer 2>/dev/null || true
systemctl enable --now snapper-cleanup.timer 2>/dev/null || true
systemctl enable limine-snapper-sync.service 2>/dev/null || true

# Disable ourselves — one-shot job done
systemctl disable snapper-init.service 2>/dev/null || true
log "Firstboot snapper init complete."
FIRSTBOOTEOF
    chmod +x /usr/local/bin/snapper-firstboot
    systemctl enable snapper-init.service 2>/dev/null || true

    info "Snapper setup complete."
else
    info "Root filesystem is not btrfs — skipping snapper setup."
fi

# ---------------------------------------------------------------------------
# NAUTILUS BOOKMARKS
# ---------------------------------------------------------------------------
if [[ -n "$MAIN_USER" && -n "$MAIN_USER_HOME" ]]; then
    info "Writing Nautilus bookmarks for $MAIN_USER..."
    mkdir -p "$MAIN_USER_HOME/.config/gtk-3.0"
    cat > "$MAIN_USER_HOME/.config/gtk-3.0/bookmarks" << EOF
file://$MAIN_USER_HOME/Desktop Desktop
file://$MAIN_USER_HOME/Downloads Downloads
file://$MAIN_USER_HOME/Documents Documents
file://$MAIN_USER_HOME/Music Music
file://$MAIN_USER_HOME/Pictures Pictures
file://$MAIN_USER_HOME/Videos Videos
EOF
    chown "$MAIN_USER:$MAIN_USER" "$MAIN_USER_HOME/.config/gtk-3.0/bookmarks"
    info "Nautilus bookmarks written."
fi

# ---------------------------------------------------------------------------
# CLEANUP — Remove dotfiles repo left in home directory
# ---------------------------------------------------------------------------
if [[ -n "$MAIN_USER" && -d "$MAIN_USER_HOME/dots-hyprland" ]]; then
    info "Cleaning up dots-hyprland repo from home directory..."
    rm -rf "$MAIN_USER_HOME/dots-hyprland"
    info "dots-hyprland removed."
fi

info "Post-install synchronization complete. System is ready for reboot."

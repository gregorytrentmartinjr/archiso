#!/usr/bin/env bash
# =============================================================================
# live-setup
# Runs once on first boot of the live ISO to set the wallpaper and
# generate Material You colors so the desktop looks correct immediately.
# This script is safe — it checks for the live ISO environment before running.
# =============================================================================

# Only run on the live ISO
if [[ ! -d "/run/archiso" ]]; then
    exit 0
fi

# Only run if this is liveuser's first session
MARKER="$HOME/.live-setup-done"
[[ -f "$MARKER" ]] && exit 0
touch "$MARKER"

DEFAULT_WALL="$HOME/.config/quickshell/ii/assets/images/default_wallpaper.png"
SWITCHWALL="$HOME/.config/quickshell/ii/scripts/colors/switchwall.sh"
# init-qs.sh normally creates the venv, but on the live ISO uv is absent and
# dots-hyprland/sdata/uv/requirements.txt doesn't exist in skel, so the venv
# is never created.  illogical-impulse-python installs materialyoucolor,
# Pillow etc. as system-wide pacman packages, so python3 works without a venv.
# We still export the path so switchwall.sh's "source .../activate" at least
# targets the right location (it will fail silently; python3 then falls back to
# system packages because switchwall.sh has no set -e).
VENV_PATH="$HOME/.local/state/quickshell/.venv"

# ---------------------------------------------------------------------------
# 1. Create a minimal illogical-impulse config so Quickshell knows which
#    wallpaper to render and enables theming.  Without this file QS has no
#    background.wallpaperPath and renders nothing.
# ---------------------------------------------------------------------------
CONFIG_DIR="$HOME/.config/illogical-impulse"
CONFIG_FILE="$CONFIG_DIR/config.json"
if [[ ! -f "$CONFIG_FILE" ]]; then
    mkdir -p "$CONFIG_DIR"
    jq -n --arg wall "$DEFAULT_WALL" '{
        "background": {
            "wallpaperPath": $wall,
            "thumbnailPath": ""
        },
        "appearance": {
            "wallpaperTheming": {
                "enableAppsAndShell": true,
                "enableQtApps": false,
                "terminalGenerationProps": {
                    "forceDarkMode": false
                }
            },
            "palette": {
                "type": "auto",
                "accentColor": ""
            }
        }
    }' > "$CONFIG_FILE"
fi

# ---------------------------------------------------------------------------
# 2. Wait for Hyprland to be ready (socket responsive)
# ---------------------------------------------------------------------------
for i in $(seq 1 30); do
    hyprctl version &>/dev/null && break
    sleep 1
done

# ---------------------------------------------------------------------------
# 3. Start swww daemon and wait until it is connected to Wayland
# ---------------------------------------------------------------------------
if ! pgrep -x swww-daemon &>/dev/null; then
    swww-daemon &
fi

for i in $(seq 1 20); do
    swww query &>/dev/null && break
    sleep 0.5
done

# Set the wallpaper via swww (belt-and-suspenders alongside QS rendering)
if [[ -f "$DEFAULT_WALL" ]]; then
    swww img "$DEFAULT_WALL" --transition-type fade --transition-duration 1 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# 4. Generate Material You colors
#    On the live ISO the venv is never created (uv is not installed and
#    requirements.txt is absent from skel).  illogical-impulse-python provides
#    the needed packages system-wide, so we skip waiting for the venv and run
#    switchwall.sh directly.  Its internal "source .../activate" will fail
#    harmlessly; python3 then uses the system-wide packages.
# ---------------------------------------------------------------------------
if command -v matugen &>/dev/null && [[ -f "$DEFAULT_WALL" ]]; then
    mkdir -p "$HOME/.local/state/quickshell/user/generated/wallpaper"

    if [[ -f "$SWITCHWALL" ]]; then
        export ILLOGICAL_IMPULSE_VIRTUAL_ENV="$VENV_PATH"
        bash "$SWITCHWALL" --image "$DEFAULT_WALL" --mode dark 2>/dev/null || true
    else
        # Fallback: basic Hyprland/SCSS colors only
        matugen image "$DEFAULT_WALL" --mode dark 2>/dev/null || true
    fi
fi

# ---------------------------------------------------------------------------
# 5. Disable lockscreen and sleep on the live ISO
#    Users are just trying out the desktop — locking/sleeping is annoying and
#    can make recovery awkward since the live password may not be obvious.
# ---------------------------------------------------------------------------
killall hypridle 2>/dev/null || true
mkdir -p "$HOME/.config/hypr"
cat > "$HOME/.config/hypr/hypridle.conf" << 'IDLE_EOF'
# Live ISO: idle actions disabled so the session never locks or suspends.
general {
    lock_cmd = hyprctl dispatch global quickshell:lock & pidof qs quickshell hyprlock || hyprlock
    before_sleep_cmd = loginctl lock-session
    after_sleep_cmd = hyprctl dispatch global quickshell:lockFocus
    inhibit_sleep = 3
}
IDLE_EOF

# Restart hypridle with the no-timeout config
hyprctl dispatch exec hypridle 2>/dev/null || true

# ---------------------------------------------------------------------------
# 6. Rebuild font cache and reload Hyprland config
# ---------------------------------------------------------------------------
fc-cache -fv 2>/dev/null || true
hyprctl reload 2>/dev/null || true

#!/usr/bin/env bash
# =============================================================================
# pre-install (Chroot Environment Preparation)
# =============================================================================

set -euo pipefail

log()  { echo "[pre-install] $*"; }
info() { log "INFO:  $*"; }
warn() { log "WARN:  $*"; }

# --- 0. Clean pacman local DB ---
# The archiso build process can leave stray %INSTALLED_DB% keys in
# /var/lib/pacman/local/*/desc files, causing pacman to spam warnings
# on every operation.  Strip them before any pacman call.
info "Cleaning stale keys from pacman local database..."
find /var/lib/pacman/local/ -type f -name "desc" -exec \
    sed -i '/^%INSTALLED_DB%$/,+2d' {} + 2>/dev/null || true

# --- 1. DNS Fix ---
# /etc/resolv.conf on the live system is a symlink to
# /run/systemd/resolve/stub-resolv.conf.  Inside the Calamares chroot,
# /run/ is an empty tmpfs so the symlink is dangling — DNS fails silently.
# Write real nameservers unconditionally so every subsequent network call works.
if [ -L /etc/resolv.conf ] || [ ! -s /etc/resolv.conf ]; then
    info "Fixing /etc/resolv.conf for chroot DNS..."
    rm -f /etc/resolv.conf
    printf 'nameserver 8.8.8.8\nnameserver 8.8.4.4\n' > /etc/resolv.conf
fi

# --- 2. Keyring & Mirror Sync ---
# Since we are already in the chroot, we initialize the keys for the target system
info "Initializing Arch Linux keyring..."
pacman-key --init
pacman-key --populate archlinux

# Only sync package databases if network is available
info "Checking network connectivity..."
if ping -c1 -W3 archlinux.org &>/dev/null; then
    # Sort mirrors by speed so all subsequent downloads are fast.
    # reflector runs on the live ISO boot, but the chroot gets a fresh
    # unsorted mirrorlist from pacman-mirrorlist — fix it here.
    if command -v reflector &>/dev/null; then
        info "Sorting mirrors by download speed (reflector)..."
        reflector --protocol https --latest 20 --sort rate --age 12 \
            --save /etc/pacman.d/mirrorlist 2>/dev/null || \
            warn "reflector failed — using existing mirrorlist."
    fi

    info "Network available — syncing package databases..."
    pacman -Sy --noconfirm
else
    warn "No network detected — skipping database sync. Packages will use cached data."
fi

# --- 3. Archiso Cleanup ---
# We must remove these because they point to the live environment's
# read-only filesystem, which causes mkinitcpio to fail on the new SSD.
info "Removing live-session hardware configurations..."

# Remove archiso-specific mkinitcpio hooks
if [ -f "/etc/mkinitcpio.conf.d/archiso.conf" ]; then
    rm -f /etc/mkinitcpio.conf.d/archiso.conf
fi

# NOTE: We intentionally do NOT delete /etc/mkinitcpio.d/linux.preset here.
# install-limine will reinstall the linux kernel which recreates it, and
# post-install owns the final mkinitcpio -P call after all config is in place.

# --- 4. Live Package Removal ---
# Remove packages that are only needed in the live ISO environment.
# This must run after pacman -Sy above so the local database exists.
# Calamares' built-in `packages` module runs before shellprocess and
# therefore before the DB sync, causing a "target not found" failure —
# so we do the removal here instead.
LIVE_PKGS=(
    calamares
    arch-install-scripts
    archinstall
    mkinitcpio-archiso
    mkinitcpio-nfs-utils
    nbd
    squashfs-tools
    syslinux
    mtools
    edk2-shell
    "memtest86+"
    memtest86+-efi
    livecd-sounds
    pv
    reflector
)

info "Removing live-only packages..."
pacman -Rns --noconfirm "${LIVE_PKGS[@]}" 2>/dev/null || \
    warn "Some live packages were not installed — continuing."

info "Pre-install environment is ready."
